# barto-cli configuration
# Default location: ~/.config/barto-cli/barto-cli.toml
# Override with: barto-cli --config-absolute-path /path/to/config.toml
# Environment variables: BARTO_CLI_<FIELD> (e.g. BARTO_CLI_BARTOS_HOST)
#
# SECRETS: Do NOT put secret values in this file.
# Store them once in the platform keychain using barto-cli:
#   barto-cli secrets set BARTO_CLI_BARTOS__API_KEY
# See SECRETS.md for details.
#
# Secret env vars (managed via platform keychain):
#   BARTO_CLI_BARTOS__API_KEY  — Bearer token for WebSocket upgrade

# A display name for this client connection.
name = "my-client"

[bartos]
# WebSocket prefix: "ws" (plain) or "wss" (TLS)
prefix = "ws"
host = "localhost"
port = 8080
# Optional: pin a specific CA certificate instead of trusting the system/Mozilla root CA store.
# When set, only TLS certificates signed by this CA are accepted (certificate pinning).
# ca_cert = "/path/to/bartos-ca.pem"
# Optional: mutual TLS — present this client certificate to bartos for authentication.
# Both client_cert and client_key must be set together.
# client_cert = "/path/to/barto-cli-client.pem"
# client_key  = "/path/to/barto-cli-client.key"

# The following secret field is intentionally omitted from this file.
# Store it via `barto-cli secrets set BARTO_CLI_BARTOS__API_KEY` (see SECRETS.md).
#
# api_key  — Bearer token sent as Authorization: Bearer <token> on WebSocket upgrade.
#            Must match api_key in bartos.toml.
#            Set via: BARTO_CLI_BARTOS__API_KEY env var

[tracing.stdout]
# with_target = false
# with_thread_ids = false
# with_thread_names = false
# with_line_number = false
# with_level = true
# directives = "barto_cli=debug"
