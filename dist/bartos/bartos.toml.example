# bartos configuration
# Default location: ~/.config/bartos/bartos.toml
# Override with: bartos --config-absolute-path /path/to/config.toml
# Environment variables: BARTOS_<FIELD> (e.g. BARTOS_MARIADB_PASSWORD)
#
# SECRETS: Do NOT put secret values in this file.
# Use systemd credentials instead — see SECRETS.md or run `barto-secrets-init`.
# Secrets are injected as env vars by the bartos-launcher wrapper at service start.
#
# Secret env vars (managed via systemd credentials):
#   BARTOS_HMAC_KEY          — shared HMAC-SHA256 key (must match bartoc)
#   BARTOS_SIGNING_KEY       — Ed25519 private key (base64-encoded)
#   BARTOS_API_KEY           — Bearer token for WebSocket upgrade
#   BARTOS_MARIADB_PASSWORD  — MariaDB password (can also stay in [mariadb] below)

[mariadb]
host = "localhost"
# port = 3306
username = "barto"
# password is set via BARTOS_MARIADB_PASSWORD env var (systemd credential)
# password = "changeme"
database = "barto"
# options = "ssl-mode=disabled"

[actix]
workers = 4
ip = "0.0.0.0"
port = 8080

# TLS configuration (optional)
# [actix.tls]
# ip = "0.0.0.0"
# port = 8443
# cert_file_path = "/etc/bartos/cert.pem"
# key_file_path = "/etc/bartos/key.pem"
# Optional: require mutual TLS — clients must present a cert signed by this CA.
# client_ca_cert = "/etc/bartos/client-ca.pem"

# The following secret fields are intentionally omitted from this file.
# Set them via systemd credentials using `barto-secrets-init` (see SECRETS.md).
#
# signing_key  — Ed25519 private key for signing BartosToBartoc messages.
#                Generate: openssl genpkey -algorithm ed25519 | openssl pkey -outform DER | tail -c 32 | base64
#
# hmac_key     — Shared HMAC-SHA256 secret for message authentication.
#                Generate: openssl rand -base64 32   (use same value in bartoc.toml)
#
# api_key      — Bearer token for WebSocket upgrade authentication.
#                Generate: openssl rand -base64 32   (use same value in bartoc/barto-cli)

[tracing.stdout]
# with_target = false
# with_thread_ids = false
# with_thread_names = false
# with_line_number = false
# with_level = true
# directives = "bartos=debug"

# [tracing.file]
# [tracing.file.layer]
# with_target = false
# with_thread_ids = false
# with_thread_names = false
# with_line_number = false
# with_level = true
# directives = "bartos=info"

# Define schedules for each bartoc client.
# The section name must match the bartoc client's `name` field.
#
# [schedules.my-worker]
# schedules = [
#   { name = "daily-check", on_calendar = "*,*,* 10:00:00", cmds = ["echo 'hello'"] },
#   { name = "hourly-task", on_calendar = "hourly", cmds = ["/opt/scripts/run.sh"] },
# ]
