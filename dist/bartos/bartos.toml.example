# bartos configuration
# Default location: ~/.config/bartos/bartos.toml
# Override with: bartos --config-absolute-path /path/to/config.toml
# Environment variables: BARTOS_<FIELD> (e.g. BARTOS_MARIADB_PASSWORD)

[mariadb]
host = "localhost"
# port = 3306
username = "barto"
password = "changeme"
database = "barto"
# options = "ssl-mode=disabled"

[actix]
workers = 4
ip = "0.0.0.0"
port = 8080

# TLS configuration (optional)
# [actix.tls]
# ip = "0.0.0.0"
# port = 8443
# cert_file_path = "/etc/bartos/cert.pem"
# key_file_path = "/etc/bartos/key.pem"
# Optional: require mutual TLS — clients must present a cert signed by this CA.
# client_ca_cert = "/etc/bartos/client-ca.pem"

# Optional: Ed25519 private key for signing all BartosToBartoc messages.
# Generate with: openssl genpkey -algorithm ed25519 | openssl pkey -outform DER | tail -c 32 | base64
# (see README for the recommended barto-keygen helper)
# signing_key = "base64encodedEd25519PrivateKey..."

# Optional: shared secret for HMAC-SHA256 authentication of outgoing messages to bartoc.
# Generate with: openssl rand -base64 32
# Must match hmac_key in bartoc.toml.
# hmac_key = "your-shared-secret-here"

# Optional: pre-shared token for Bearer authentication on WebSocket upgrades.
# When set, bartoc and barto-cli must send Authorization: Bearer <token> on connect.
# Generate with: openssl rand -base64 32
# Must match api_key in bartoc.toml and barto-cli.toml.
# api_key = "your-secret-token-here"

[tracing.stdout]
# with_target = false
# with_thread_ids = false
# with_thread_names = false
# with_line_number = false
# with_level = true
# directives = "bartos=debug"

# [tracing.file]
# [tracing.file.layer]
# with_target = false
# with_thread_ids = false
# with_thread_names = false
# with_line_number = false
# with_level = true
# directives = "bartos=info"

# Define schedules for each bartoc client.
# The section name must match the bartoc client's `name` field.
#
# [schedules.my-worker]
# schedules = [
#   { name = "daily-check", on_calendar = "*,*,* 10:00:00", cmds = ["echo 'hello'"] },
#   { name = "hourly-task", on_calendar = "hourly", cmds = ["/opt/scripts/run.sh"] },
# ]
