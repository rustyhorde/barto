/var/log/bartos/bartos.log.????-??-?? {
    daily
    missingok
    notifempty
    nocreate
    compress
    compresscmd /usr/bin/xz
    compressext .xz
    rotate 7
    sharedscripts
    postrotate
        find /var/log/bartos -name 'bartos.log.*.xz' -mtime +7 -delete 2>/dev/null || true
    endscript
}
