#!/bin/sh
# Loads bartoc secrets and exports them as environment variables before exec-ing bartoc.
#
# Two secret sources are supported (checked in priority order):
#
# 1. systemd user credentials — recommended for lingering services started at
#    boot (before any interactive login). Set up once with bartoc-secrets-init,
#    which generates SetCredentialEncrypted= lines for:
#      ~/.config/systemd/user/bartoc.service.d/secrets.conf
#
# 2. Platform keychain (GNOME Keyring / KWallet via libsecret) — suitable for
#    desktop sessions that are always logged in when bartoc starts. Requires
#    libsecret (secret-tool) and an unlocked keychain. Store secrets with:
#      barto-cli secrets set BARTOC_HMAC_KEY
#      barto-cli secrets set BARTOC_SERVER_PUBLIC_KEY
#      barto-cli secrets set BARTOC_BARTOS__API_KEY
#
# See SECRETS.md for the full setup workflow.
set -e

# Primary: systemd user credentials (works for lingering services started at boot)
if [ -n "${CREDENTIALS_DIRECTORY:-}" ]; then
    for cred in hmac_key server_public_key api_key; do
        path="${CREDENTIALS_DIRECTORY}/${cred}"
        [ -f "$path" ] || continue
        case "$cred" in
            hmac_key)
                BARTOC_HMAC_KEY=$(cat "$path")
                export BARTOC_HMAC_KEY
                ;;
            server_public_key)
                BARTOC_SERVER_PUBLIC_KEY=$(cat "$path")
                export BARTOC_SERVER_PUBLIC_KEY
                ;;
            api_key)
                BARTOC_BARTOS__API_KEY=$(cat "$path")
                export BARTOC_BARTOS__API_KEY
                ;;
        esac
    done
fi

# Fallback: platform keychain (fills any gaps not covered by systemd credentials)
load_secret() {
    secret-tool lookup service barto username "$1" 2>/dev/null || true
}

if command -v secret-tool > /dev/null 2>&1; then
    if [ -z "${BARTOC_HMAC_KEY:-}" ]; then
        val=$(load_secret BARTOC_HMAC_KEY)
        if [ -n "$val" ]; then
            BARTOC_HMAC_KEY="$val"
            export BARTOC_HMAC_KEY
        fi
    fi

    if [ -z "${BARTOC_SERVER_PUBLIC_KEY:-}" ]; then
        val=$(load_secret BARTOC_SERVER_PUBLIC_KEY)
        if [ -n "$val" ]; then
            BARTOC_SERVER_PUBLIC_KEY="$val"
            export BARTOC_SERVER_PUBLIC_KEY
        fi
    fi

    if [ -z "${BARTOC_BARTOS__API_KEY:-}" ]; then
        val=$(load_secret BARTOC_BARTOS__API_KEY)
        if [ -n "$val" ]; then
            BARTOC_BARTOS__API_KEY="$val"
            export BARTOC_BARTOS__API_KEY
        fi
    fi
fi

exec /usr/bin/bartoc "$@"
