#!/bin/sh
# bartoc-secrets-init — interactive setup of systemd user credentials for bartoc.
#
# Use this when bartoc runs as a lingering user service that starts at boot
# before any interactive login (GNOME Keyring is not unlocked at that point).
# For desktop sessions where the user is always logged in when bartoc starts,
# the platform keychain via `barto-cli secrets set` is sufficient instead.
#
# Usage:
#   bartoc-secrets-init
#
# Requirements:
#   systemd >= 252  (SetCredentialEncrypted= for user services)
#
# Output:
#   SetCredentialEncrypted= lines to paste into a drop-in file:
#     ~/.config/systemd/user/bartoc.service.d/secrets.conf
#
# Then reload and restart:
#   systemctl --user daemon-reload && systemctl --user restart bartoc
set -e

if ! command -v systemd-creds > /dev/null 2>&1; then
    echo "ERROR: systemd-creds not found. Requires systemd >= 252." >&2
    exit 1
fi

# Detect TPM2 availability for informational purposes only.
tpm_note=""
if systemd-creds --has-tpm2 > /dev/null 2>&1; then
    tpm_note=" (TPM2 hardware-binding active)"
else
    tpm_note=" (machine-key binding, no TPM2)"
fi

echo ""
echo "==> bartoc-secrets-init: bartoc systemd user credential setup${tpm_note}"
echo ""
echo "    Each secret you enter will be encrypted and printed as a"
echo "    SetCredentialEncrypted= line for bartoc.service."
echo "    Leave any prompt blank to skip that secret."
echo ""
echo "    Add the output to:"
echo "      ~/.config/systemd/user/bartoc.service.d/secrets.conf"
echo ""
echo "      [Service]"
echo "      SetCredentialEncrypted=hmac_key: \\"
echo "          <blob>"
echo "      ..."
echo ""
echo "    Then:  systemctl --user daemon-reload && systemctl --user restart bartoc"
echo ""

secrets="hmac_key:Shared HMAC-SHA256 key (must match bartos hmac_key)
server_public_key:Ed25519 public key to verify messages from bartos (base64-encoded)
api_key:Bearer token for WebSocket upgrade"

echo "---- SetCredentialEncrypted lines (add to [Service] section) ----"
echo ""

IFS="
"
for entry in $secrets; do
    name="${entry%%:*}"
    desc="${entry#*:}"

    printf "  %s (%s)\n  Value (blank to skip): " "$name" "$desc"
    stty -echo 2>/dev/null || true
    read -r value
    stty echo 2>/dev/null || true
    echo ""

    if [ -n "$value" ]; then
        blob=$(printf '%s' "$value" | systemd-creds encrypt --name="$name" - -)
        echo "SetCredentialEncrypted=${name}: \\"
        echo "        ${blob}"
        echo ""
    fi
done
unset IFS

echo "-----------------------------------------------------------------"
echo ""
echo "Copy the lines above into:"
echo "  ~/.config/systemd/user/bartoc.service.d/secrets.conf"
echo ""
echo "Then reload and restart:"
echo "  systemctl --user daemon-reload && systemctl --user restart bartoc"
echo ""
