#!/bin/sh
set -e
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/bartoc"
CONF=$(mktemp)
trap 'rm -f "$CONF"' EXIT
cat > "$CONF" <<EOF
$STATE_DIR/bartoc.log.????-??-?? {
    daily
    missingok
    notifempty
    nocreate
    compress
    compresscmd /usr/bin/xz
    compressext .xz
    rotate 7
    sharedscripts
    postrotate
        find $STATE_DIR -name 'bartoc.log.*.xz' -mtime +7 -delete 2>/dev/null || true
    endscript
}
EOF
logrotate --state "$STATE_DIR/logrotate.status" "$CONF"
