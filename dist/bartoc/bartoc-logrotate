#!/bin/sh
set -e
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/bartoc"
CONF=$(mktemp)
trap 'rm -f "$CONF"' EXIT
cat > "$CONF" <<EOF
$STATE_DIR/bartoc.log* {
    daily
    missingok
    notifempty
    nocreate
    compress
    compresscmd /usr/bin/xz
    compressext .xz
    maxage 7
    rotate 0
}
EOF
logrotate --state "$STATE_DIR/logrotate.status" "$CONF"
