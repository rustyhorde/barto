# bartoc configuration
# Default location: ~/.config/bartoc/bartoc.toml
# Override with: bartoc --config-absolute-path /path/to/config.toml
# Environment variables: BARTOC_<FIELD> (e.g. BARTOC_BARTOS_HOST)
#
# SECRETS: Do NOT put secret values in this file.
# Store them once in the platform keychain using barto-cli:
#   barto-cli secrets set BARTOC_HMAC_KEY
#   barto-cli secrets set BARTOC_SERVER_PUBLIC_KEY
#   barto-cli secrets set BARTOC_BARTOS__API_KEY
# bartoc-launcher loads them automatically at startup — see SECRETS.md.
#
# Secret env vars (managed via platform keychain):
#   BARTOC_HMAC_KEY            — shared HMAC-SHA256 key (must match bartos)
#   BARTOC_SERVER_PUBLIC_KEY   — Ed25519 public key to verify bartos messages
#   BARTOC_BARTOS__API_KEY      — Bearer token for WebSocket upgrade

# The name of this bartoc instance.
# Must match the section name in the bartos schedules config (e.g. [schedules.my-worker]).
name = "my-worker"

# Number of times to retry connecting to bartos on startup.
retry_count = 3

# Client timeout in seconds (optional)
# client_timeout = 30

# Behavior when a scheduled tick is missed: "Burst", "Delay", or "Skip"
# missed_tick = "Burst"

[bartos]
# WebSocket prefix: "ws" (plain) or "wss" (TLS)
prefix = "ws"
host = "localhost"
port = 8080
# Optional: pin a specific CA certificate instead of trusting the system/Mozilla root CA store.
# When set, only TLS certificates signed by this CA are accepted (certificate pinning).
# ca_cert = "/path/to/bartos-ca.pem"
# Optional: mutual TLS — present this client certificate to bartos for authentication.
# Both client_cert and client_key must be set together.
# client_cert = "/path/to/bartoc-client.pem"
# client_key  = "/path/to/bartoc-client.key"

# The following secret fields are intentionally omitted from this file.
# Store them via `barto-cli secrets set <KEY>` (see SECRETS.md).
#
# server_public_key — base64-encoded Ed25519 public key of the bartos server.
#                     Set via: BARTOC_SERVER_PUBLIC_KEY env var
#
# hmac_key          — shared HMAC-SHA256 secret for message authentication.
#                     Set via: BARTOC_HMAC_KEY env var
#                     replay_window_secs = 60  (optional, default 60)
#
# api_key           — Bearer token sent on WebSocket upgrade.
#                     Set via: BARTOC_BARTOS__API_KEY env var

[tracing.stdout]
# with_target = false
# with_thread_ids = false
# with_thread_names = false
# with_line_number = false
# with_level = true
# directives = "bartoc=debug"

# [tracing.file]
# [tracing.file.layer]
# with_target = false
# with_level = true
