# bartoc configuration
# Default location: ~/.config/bartoc/bartoc.toml
# Override with: bartoc --config-absolute-path /path/to/config.toml
# Environment variables: BARTOC_<FIELD> (e.g. BARTOC_BARTOS_HOST)

# The name of this bartoc instance.
# Must match the section name in the bartos schedules config (e.g. [schedules.my-worker]).
name = "my-worker"

# Number of times to retry connecting to bartos on startup.
retry_count = 3

# Client timeout in seconds (optional)
# client_timeout = 30

# Behavior when a scheduled tick is missed: "Burst", "Delay", or "Skip"
# missed_tick = "Burst"

[bartos]
# WebSocket prefix: "ws" (plain) or "wss" (TLS)
prefix = "ws"
host = "localhost"
port = 8080
# Optional: pin a specific CA certificate instead of trusting the system/Mozilla root CA store.
# When set, only TLS certificates signed by this CA are accepted (certificate pinning).
# ca_cert = "/path/to/bartos-ca.pem"
# Optional: mutual TLS — present this client certificate to bartos for authentication.
# Both client_cert and client_key must be set together.
# client_cert = "/path/to/bartoc-client.pem"
# client_key  = "/path/to/bartoc-client.key"

# Optional: base64-encoded Ed25519 public key of the bartos server.
# When set, incoming messages that lack a valid signature are rejected.
# server_public_key = "base64encodedEd25519PublicKey..."

[tracing.stdout]
# with_target = false
# with_thread_ids = false
# with_thread_names = false
# with_line_number = false
# with_level = true
# directives = "bartoc=debug"

# [tracing.file]
# [tracing.file.layer]
# with_target = false
# with_level = true
