#!/bin/sh
# barto-secrets-init — interactive first-time secrets setup for bartos.
#
# Encrypts each bartos secret with systemd-creds and prints the
# SetCredentialEncrypted= lines to paste into bartos.service (or a drop-in
# at /etc/systemd/system/bartos.service.d/secrets.conf).
#
# Usage:
#   barto-secrets-init
#
# Requirements:
#   systemd >= 250  (systemd-creds encrypt)
#
# For bartoc / barto-cli secrets use `barto-cli secrets set <KEY>` instead.
set -e

if ! command -v systemd-creds > /dev/null 2>&1; then
    echo "ERROR: systemd-creds not found. Requires systemd >= 250." >&2
    exit 1
fi

# Detect TPM2 availability for informational purposes only.
tpm_note=""
if systemd-creds --has-tpm2 > /dev/null 2>&1; then
    tpm_note=" (TPM2 hardware-binding active)"
else
    tpm_note=" (machine-key binding, no TPM2)"
fi

echo ""
echo "==> barto-secrets-init: bartos systemd credential setup${tpm_note}"
echo ""
echo "    Each secret you enter will be encrypted and printed as a"
echo "    SetCredentialEncrypted= line for bartos.service."
echo "    Leave any prompt blank to skip that secret."
echo ""
echo "    Add the output to /etc/systemd/system/bartos.service.d/secrets.conf:"
echo ""
echo "      [Service]"
echo "      SetCredentialEncrypted=hmac_key: \\"
echo "          <blob>"
echo "      ..."
echo ""
echo "    Then:  systemctl daemon-reload && systemctl restart bartos"
echo ""

encrypt_secret() {
    local name="$1"
    local value="$2"
    printf '%s' "$value" | systemd-creds encrypt --name="$name" - -
}

prompt_secret() {
    local name="$1"
    local desc="$2"
    printf "  %s (%s): " "$name" "$desc"
    # Disable echo for secret input
    stty -echo 2>/dev/null || true
    read -r value
    stty echo 2>/dev/null || true
    echo ""
    echo "$value"
}

secrets="hmac_key:Shared HMAC-SHA256 key (must match bartoc hmac_key)
signing_key:Ed25519 private key (base64-encoded)
api_key:Bearer token for WebSocket upgrade
mariadb_password:MariaDB database password"

output_lines=""

echo "---- SetCredentialEncrypted lines (add to [Service] section) ----"
echo ""

IFS="
"
for entry in $secrets; do
    name="${entry%%:*}"
    desc="${entry#*:}"

    printf "  %s (%s)\n  Value (blank to skip): " "$name" "$desc"
    stty -echo 2>/dev/null || true
    read -r value
    stty echo 2>/dev/null || true
    echo ""

    if [ -n "$value" ]; then
        blob=$(printf '%s' "$value" | systemd-creds encrypt --name="$name" - -)
        echo "SetCredentialEncrypted=${name}: \\"
        echo "        ${blob}"
        echo ""
    fi
done
unset IFS

echo "-----------------------------------------------------------------"
echo ""
echo "Copy the lines above into:"
echo "  /etc/systemd/system/bartos.service.d/secrets.conf"
echo ""
echo "Then reload and restart:"
echo "  systemctl daemon-reload && systemctl restart bartos"
echo ""
