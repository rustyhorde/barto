#!/bin/sh
# bartoc-secrets-init — interactive setup of systemd user credentials for bartoc.
#
# Use this when bartoc runs as a lingering user service that starts at boot
# before any interactive login (GNOME Keyring is not unlocked at that point).
# For desktop sessions where the user is always logged in when bartoc starts,
# the platform keychain via `barto-cli secrets set` is sufficient instead.
#
# Usage:
#   bartoc-secrets-init
#
# Requirements:
#   systemd >= 256  (user service credential encryption)
#
# Output:
#   SetCredentialEncrypted= lines to paste into a drop-in file:
#     ~/.config/systemd/user/bartoc.service.d/secrets.conf
#
# Then reload and restart:
#   systemctl --user daemon-reload && systemctl --user restart bartoc
set -e

if ! command -v systemd-creds > /dev/null 2>&1; then
    echo "ERROR: systemd-creds not found. Requires systemd >= 256." >&2
    exit 1
fi

SYSTEMD_VERSION=$(systemd-creds --version 2>/dev/null | awk 'NR==1{print $2}')
if [ -z "$SYSTEMD_VERSION" ] || [ "$SYSTEMD_VERSION" -lt 250 ]; then
    echo "ERROR: Requires systemd >= 256 for user service credential encryption." >&2
    exit 1
fi

# SetCredentialEncrypted= in user services requires systemd >= 256.
# On older versions the user service manager cannot decrypt machine-key blobs
# (/var/lib/systemd/credential.secret is 0600 root:root and the user manager
# runs unprivileged), so the service fails at startup with status=243/CREDENTIALS.
if [ "$SYSTEMD_VERSION" -lt 256 ]; then
    echo "ERROR: systemd ${SYSTEMD_VERSION} does not support encrypted credentials" >&2
    echo "       in user services (requires systemd >= 256)." >&2
    echo "" >&2
    echo "       Options:" >&2
    echo "         1. Upgrade to systemd >= 256 and re-run bartoc-secrets-init." >&2
    echo "         2. Use the platform keychain instead:" >&2
    echo "              barto-cli secrets set BARTOC_HMAC_KEY" >&2
    echo "              barto-cli secrets set BARTOC_SERVER_PUBLIC_KEY" >&2
    echo "              barto-cli secrets set BARTOC_BARTOS__API_KEY" >&2
    echo "         3. Use age-encrypted secrets (no systemd version requirement):" >&2
    echo "              bartoc-age-secrets-init" >&2
    exit 1
fi

# Detect TPM2 availability for informational purposes only.
tpm_note=""
if systemd-creds --has-tpm2 > /dev/null 2>&1; then
    tpm_note=" (TPM2 hardware-binding active)"
else
    tpm_note=" (machine-key binding, no TPM2)"
fi

echo ""
echo "==> bartoc-secrets-init: bartoc systemd user credential setup (systemd ${SYSTEMD_VERSION})${tpm_note}"
echo ""
echo "    Each secret you enter will be encrypted and printed as a"
echo "    SetCredentialEncrypted= line for bartoc.service."
echo "    Leave any prompt blank to skip that secret."
echo ""
echo "    Add the output to:"
echo "      ~/.config/systemd/user/bartoc.service.d/secrets.conf"
echo ""
echo "      [Service]"
echo "      SetCredentialEncrypted=hmac_key: \\"
echo "          <blob>"
echo "      ..."
echo ""
echo "    Then:  systemctl --user daemon-reload && systemctl --user restart bartoc"
echo ""

encrypt_secret() {
    local name="$1"
    local value="$2"
    if [ "$SYSTEMD_VERSION" -ge 256 ]; then
        printf '%s' "$value" | systemd-creds encrypt --user --name="$name" - -
    else
        printf '%s' "$value" | systemd-creds encrypt --name="$name" - -
    fi
}

prompt_secret() {
    local name="$1"
    local desc="$2"
    printf "  %s (%s)\n  Value (blank to skip): " "$name" "$desc" >/dev/tty
    stty -echo </dev/tty 2>/dev/null || true
    read -r value </dev/tty
    stty echo </dev/tty 2>/dev/null || true
    printf "\n" >/dev/tty
    printf '%s' "$value"
}

secrets="hmac_key:Shared HMAC-SHA256 key (must match bartos hmac_key)
server_public_key:Ed25519 public key to verify messages from bartos (base64-encoded)
api_key:Bearer token for WebSocket upgrade"

echo "---- SetCredentialEncrypted lines (add to [Service] section) ----"
echo ""

IFS="
"
for entry in $secrets; do
    name="${entry%%:*}"
    desc="${entry#*:}"
    value=$(prompt_secret "$name" "$desc")
    if [ -n "$value" ]; then
        blob=$(encrypt_secret "$name" "$value")
        echo "SetCredentialEncrypted=${name}: \\"
        echo "        ${blob}"
        echo ""
    fi
done
unset IFS

echo "-----------------------------------------------------------------"
echo ""
echo "Copy the lines above into:"
echo "  ~/.config/systemd/user/bartoc.service.d/secrets.conf"
echo ""
echo "Then reload and restart:"
echo "  systemctl --user daemon-reload && systemctl --user restart bartoc"
echo ""
