#!/bin/sh
# bartoc-age-secrets-init — age-encrypted secret setup for bartoc.
#
# Use for systems with systemd 250-255 that cannot use SetCredentialEncrypted=
# in user services.  Generates an age keypair, prompts for the three bartoc
# secrets, and writes them encrypted to ~/.config/bartoc/secrets.age.  The
# bartoc-age-launcher decrypts in memory at service startup — no plaintext
# secrets file is written to disk.
#
# Usage:
#   bartoc-age-secrets-init
#
# Requirements:
#   age >= 1.0  (https://age-encryption.org/)
#     Arch:          sudo pacman -S age
#     Debian/Ubuntu: sudo apt install age
#     Fedora:        sudo dnf install age
#
# Creates:
#   ~/.config/bartoc/age-identity  (mode 0600) — age keypair (keep private)
#   ~/.config/bartoc/secrets.age   (mode 0600) — age-encrypted KEY=VALUE pairs
#
# Then install and enable the age service variant:
#   systemctl --user disable --now bartoc.service   # if currently active
#   systemctl --user enable  --now bartoc-age.service
set -e

if ! command -v age > /dev/null 2>&1; then
    echo "ERROR: age not found." >&2
    echo "" >&2
    echo "       Install age:" >&2
    echo "         Arch:          sudo pacman -S age" >&2
    echo "         Debian/Ubuntu: sudo apt install age" >&2
    echo "         Fedora:        sudo dnf install age" >&2
    exit 1
fi

if ! command -v age-keygen > /dev/null 2>&1; then
    echo "ERROR: age-keygen not found (should be installed alongside age)." >&2
    exit 1
fi

cfg="${XDG_CONFIG_HOME:-$HOME/.config}/bartoc"
identity="$cfg/age-identity"
secrets_age="$cfg/secrets.age"

mkdir -p -m 0700 "$cfg"

if [ ! -f "$identity" ]; then
    echo "==> Generating age identity at $identity ..."
    age-keygen -o "$identity" 2>/dev/null
    chmod 0600 "$identity"
    echo "    Done."
    echo ""
else
    echo "==> Using existing age identity at $identity"
    echo ""
fi

pubkey=$(age-keygen -y "$identity")

echo "==> bartoc-age-secrets-init: age-encrypted secrets setup"
echo ""
echo "    Each secret you enter will be encrypted with your age identity."
echo "    Leave any prompt blank to skip that secret."
echo ""
echo "    age identity: $identity"
echo "    secrets file: $secrets_age"
echo ""

prompt_secret() {
    local name="$1"
    local desc="$2"
    printf "  %s (%s)\n  Value (blank to skip): " "$name" "$desc" >/dev/tty
    stty -echo </dev/tty 2>/dev/null || true
    read -r value </dev/tty
    stty echo </dev/tty 2>/dev/null || true
    printf "\n" >/dev/tty
    printf '%s' "$value"
}

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

# Read existing secrets.age content to preserve any skipped values
existing_hmac=""
existing_pubkey=""
existing_apikey=""
if [ -f "$secrets_age" ] && command -v age > /dev/null 2>&1; then
    existing=$(age -d -i "$identity" "$secrets_age" 2>/dev/null || true)
    IFS="
"
    for line in $existing; do
        k="${line%%=*}"
        v="${line#*=}"
        case "$k" in
            BARTOC_HMAC_KEY)         existing_hmac="$v"    ;;
            BARTOC_SERVER_PUBLIC_KEY) existing_pubkey="$v"  ;;
            BARTOC_BARTOS__API_KEY)  existing_apikey="$v"  ;;
        esac
    done
    unset IFS
fi

hmac=$(prompt_secret "BARTOC_HMAC_KEY" "Shared HMAC-SHA256 key (must match bartos hmac_key)")
[ -z "$hmac" ] && hmac="$existing_hmac"

pubkey_val=$(prompt_secret "BARTOC_SERVER_PUBLIC_KEY" "Ed25519 public key to verify messages from bartos (base64-encoded)")
[ -z "$pubkey_val" ] && pubkey_val="$existing_pubkey"

apikey=$(prompt_secret "BARTOC_BARTOS__API_KEY" "Bearer token for WebSocket upgrade")
[ -z "$apikey" ] && apikey="$existing_apikey"

# Write only non-empty values
{
    [ -n "$hmac" ]       && printf 'BARTOC_HMAC_KEY=%s\n'          "$hmac"
    [ -n "$pubkey_val" ] && printf 'BARTOC_SERVER_PUBLIC_KEY=%s\n' "$pubkey_val"
    [ -n "$apikey" ]     && printf 'BARTOC_BARTOS__API_KEY=%s\n'   "$apikey"
} > "$tmp"

if [ ! -s "$tmp" ]; then
    echo "" >&2
    echo "No secrets entered — secrets.age not updated." >&2
    exit 0
fi

age -r "$pubkey" -o "$secrets_age" "$tmp"
chmod 0600 "$secrets_age"

echo ""
echo "==> Encrypted secrets written to $secrets_age"
echo ""
echo "    To use these secrets, enable the age service variant:"
echo ""
echo "      systemctl --user disable --now bartoc.service   # if currently active"
echo "      systemctl --user enable  --now bartoc-age.service"
echo "      systemctl --user daemon-reload"
echo ""
echo "    To update a secret later, re-run bartoc-age-secrets-init."
echo ""
