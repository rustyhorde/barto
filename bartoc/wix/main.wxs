<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX installer for bartoc — the barto worker client.

  Service account configuration (passed at install time or via msiexec):
    SERVICEACCOUNT   — Windows account to run the service (default: LocalService)
    SERVICEPASSWORD  — Password for the service account (leave empty for built-in accounts)

  Example install with a specific user account:
    msiexec /i bartoc-VERSION-x86_64.msi ^
      SERVICEACCOUNT=".\bartoc_svc" SERVICEPASSWORD="s3cr3t" /l*v install.log

  Secret management:
    Run `barto-cli secrets set BARTOC_HMAC_KEY` (and the other two secrets) as the
    service account user before starting the service.  bartoc reads secrets from the
    Windows Credential Manager at startup when they are not already set as environment
    variables.

    See packaging/wix/README.Windows.md for the full setup guide.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <Product Id="*"
           Name="bartoc"
           Language="1033"
           Version="!(bind.FileVersion.bartoc_exe)"
           Manufacturer="Jason Ozias"
           UpgradeCode="603E230A-F336-48C4-8E7C-0AE68445D111">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="bartoc — barto worker client"
             Manufacturer="Jason Ozias"/>

    <MajorUpgrade DowngradeErrorMessage="A newer version of bartoc is already installed."/>
    <MediaTemplate EmbedCab="yes"/>

    <!-- Service account properties — override via msiexec command line -->
    <Property Id="SERVICEACCOUNT" Value="NT AUTHORITY\LocalService"/>
    <Property Id="SERVICEPASSWORD"/>

    <Property Id="ARPHELPLINK" Value="https://github.com/rustyhorde/barto/issues"/>
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/rustyhorde/barto"/>

    <!-- ── Directory layout ───────────────────────────────────────────────── -->
    <Directory Id="TARGETDIR" Name="SourceDir">

      <!-- %ProgramFiles%\barto\bartoc\bartoc.exe -->
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="BARTO_DIR" Name="barto">
          <Directory Id="APPLICATIONFOLDER" Name="bartoc">

            <Component Id="bartoc_binary"
                       Guid="7C048458-9406-4777-9E98-8C5127794DA9"
                       Win64="yes">
              <File Id="bartoc_exe"
                    Name="bartoc.exe"
                    Source="..\..\target\x86_64-pc-windows-msvc\release\bartoc.exe"
                    KeyPath="yes"/>

              <!--
                The service is configured to run as [SERVICEACCOUNT].
                The service flag puts bartoc into SCM dispatch mode;
                remaining arguments point config/redb at %ProgramData%\bartoc\.
              -->
              <ServiceInstall Id="BartocService"
                              Name="bartoc"
                              DisplayName="Barto Worker Client"
                              Description="Executes scheduled jobs and reports results to a bartos instance."
                              Type="ownProcess"
                              Start="auto"
                              ErrorControl="normal"
                              Account="[SERVICEACCOUNT]"
                              Password="[SERVICEPASSWORD]"
                              Arguments="--service --config-absolute-path &quot;[CommonAppDataFolder]bartoc\bartoc.toml&quot; --tracing-absolute-path &quot;[CommonAppDataFolder]bartoc\bartoc.log&quot; --redb-absolute-path &quot;[CommonAppDataFolder]bartoc\bartoc.redb&quot;"/>

              <!-- Delayed auto-start; restart on first two failures. -->
              <util:ServiceConfig ServiceName="bartoc"
                                  FirstFailureActionType="restart"
                                  SecondFailureActionType="restart"
                                  ThirdFailureActionType="none"
                                  RestartServiceDelayInSeconds="10"
                                  ResetPeriodInDays="1"
                                  DelayedAutoStart="yes"/>

              <ServiceControl Id="StartBartocService"
                              Name="bartoc"
                              Start="install"
                              Stop="both"
                              Remove="uninstall"
                              Wait="yes"/>
            </Component>

          </Directory>
        </Directory>
      </Directory>

      <!-- %ProgramData%\bartoc\ — example config and PS1 launcher -->
      <Directory Id="CommonAppDataFolder">
        <Directory Id="BARTOC_DATA_DIR" Name="bartoc">

          <Component Id="bartoc_config_files"
                     Guid="E9DEFC07-E3D0-45F5-91D9-94ABAC93A80F"
                     Win64="yes">
            <File Id="bartoc_toml_example"
                  Name="bartoc.toml.example"
                  Source="..\..\packaging\arch\bartoc\examples\bartoc.toml.example"/>
            <File Id="bartoc_launcher_ps1"
                  Name="bartoc-launcher.ps1"
                  Source="..\..\packaging\scripts\bartoc-launcher.ps1"/>
          </Component>

        </Directory>
      </Directory>

    </Directory>

    <!-- ── Features ──────────────────────────────────────────────────────── -->
    <Feature Id="MainFeature"
             Title="bartoc"
             Level="1">
      <ComponentRef Id="bartoc_binary"/>
      <ComponentRef Id="bartoc_config_files"/>
    </Feature>

  </Product>
</Wix>
